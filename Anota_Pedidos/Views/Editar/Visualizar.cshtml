@model Anota_Pedidos.ViewModels.GerenciarCardapioViewModel

@{
    ViewData["Title"] = "Visualizar Cardápio";
    Layout = null;

    // Obter estabelecimento da sessão
    var estabelecimentoJson = Context.Session.GetString("Estabelecimento");
    EstabelecimentoSessionDTO estabelecimento = null;

    if (!string.IsNullOrEmpty(estabelecimentoJson))
    {
        estabelecimento = JsonSerializer.Deserialize<EstabelecimentoSessionDTO>(estabelecimentoJson);
    }
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Visualizar Cardápio • Alfa Prime</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #0f172a;
            --primary-light: #1e293b;
            --secondary: #f97316;
            --secondary-light: #fb923c;
            --accent: #06b6d4;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --bg-light: #f8fafc;
            --bg-dark: #0b1120;
            --card-bg: #ffffff;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --border-light: #e2e8f0;
            --border-focus: #f97316;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
            --shadow: 0 10px 40px -15px rgba(0,0,0,0.2);
            --shadow-lg: 0 25px 50px -12px rgba(0,0,0,0.25);
            --shadow-xl: 0 35px 60px -15px rgba(0,0,0,0.3);
            --radius-sm: 12px;
            --radius: 20px;
            --radius-lg: 32px;
            --radius-xl: 40px;
            --transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg-light);
            color: var(--text-primary);
            line-height: 1.5;
        }

        /* ==================== APP BAR MODERNA ==================== */
        .app-bar {
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(10px);
            color: white;
            padding: 1rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 40;
            box-shadow: var(--shadow);
        }

        .app-title {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            cursor: pointer;
        }

        .establishment-photo {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            overflow: hidden;
            border: 2px solid var(--secondary);
            cursor: pointer;
            transition: var(--transition);
            background: linear-gradient(135deg, #fff7ed, #ffedd5);
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .establishment-photo:hover {
                transform: scale(1.05);
                box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.3);
            }

            .establishment-photo img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .establishment-photo i {
                font-size: 1.5rem;
                color: var(--secondary);
            }

        .app-title h1 {
            font-size: 1.3rem;
            font-weight: 600;
            letter-spacing: -0.3px;
            background: linear-gradient(135deg, #fff, #f97316);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .back-btn {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            width: 44px;
            height: 44px;
            border-radius: 14px;
            font-size: 1.2rem;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .back-btn:hover {
                background: rgba(255, 255, 255, 0.2);
                transform: scale(1.05);
            }

        /* ==================== HERO MODERNO ==================== */
        .hero {
            background: linear-gradient(135deg, var(--primary), #1e1b4b);
            padding: 3rem 1.5rem;
            color: white;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .hero::before {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(249,115,22,0.15) 0%, transparent 70%);
                animation: rotateHero 20s linear infinite;
            }

        @@keyframes rotateHero {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        .hero h2 {
            font-size: 2.2rem;
            margin-bottom: 0.5rem;
            position: relative;
            z-index: 1;
        }

        .hero p {
            opacity: 0.9;
            font-size: 1.1rem;
            position: relative;
            z-index: 1;
        }

        /* ==================== SEARCH MODERNA ==================== */
        .search-container {
            max-width: 600px;
            margin: -1.8rem auto 1.5rem;
            padding: 0 1.5rem;
            position: relative;
            z-index: 10;
        }

        .search-bar {
            width: 100%;
            padding: 1.2rem 1.2rem 1.2rem 3.5rem;
            border: none;
            border-radius: var(--radius-xl);
            font-size: 1rem;
            box-shadow: 0 20px 35px -10px rgba(0,0,0,0.2);
            transition: all 0.3s ease;
        }

            .search-bar:focus {
                outline: none;
                transform: translateY(-2px);
                box-shadow: 0 25px 40px -12px rgba(249,115,22,0.3);
            }

        .search-icon {
            position: absolute;
            left: 2.5rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 1.2rem;
        }

        /* ==================== CATEGORIAS MODERNAS ==================== */
        .categories {
            padding: 0 1.5rem 1rem;
            overflow-x: auto;
            white-space: nowrap;
            scrollbar-width: none;
            -ms-overflow-style: none;
            cursor: grab;
        }

            .categories:active {
                cursor: grabbing;
            }

            .categories::-webkit-scrollbar {
                display: none;
            }

        .category-chip {
            display: inline-block;
            padding: 0.8rem 1.5rem;
            margin-right: 0.8rem;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(5px);
            border: 2px solid var(--border-light);
            border-radius: 100px;
            font-weight: 600;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .category-chip:hover {
                border-color: var(--secondary);
                color: var(--secondary);
                transform: translateY(-2px);
            }

            .category-chip.active {
                background: linear-gradient(135deg, var(--secondary), #ea580c);
                border-color: var(--secondary);
                color: white;
                box-shadow: 0 4px 15px rgba(249,115,22,0.3);
            }

        /* ==================== MENU GRID MODERNO ==================== */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 1.5rem;
            padding: 1.5rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .menu-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            border: 1px solid rgba(255, 255, 255, 0.2);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: row;
            padding: 1rem;
            gap: 1rem;
            position: relative;
            animation: fadeInUp 0.5s ease-out;
            animation-fill-mode: both;
        }

            .menu-card:nth-child(1) {
                animation-delay: 0.05s;
            }

            .menu-card:nth-child(2) {
                animation-delay: 0.1s;
            }

            .menu-card:nth-child(3) {
                animation-delay: 0.15s;
            }

            .menu-card:nth-child(4) {
                animation-delay: 0.2s;
            }

            .menu-card:nth-child(5) {
                animation-delay: 0.25s;
            }

            .menu-card:nth-child(6) {
                animation-delay: 0.3s;
            }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .menu-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.2);
            border-color: var(--secondary);
        }

        .menu-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 50%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s;
        }

        .menu-card:hover::after {
            left: 100%;
        }

        .menu-info {
            flex: 2;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .menu-header {
            margin-bottom: 0.5rem;
        }

            .menu-header h3 {
                font-size: 1.2rem;
                font-weight: 600;
                color: var(--primary);
                margin-bottom: 0.25rem;
            }

        .menu-price {
            font-size: 1.2rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--secondary), #ea580c);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }

        .menu-description {
            color: var(--text-secondary);
            font-size: 0.85rem;
            margin-bottom: 0.8rem;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .menu-footer {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            flex-wrap: wrap;
        }

        .menu-category {
            background: var(--bg-light);
            padding: 0.3rem 0.8rem;
            border-radius: 100px;
            font-size: 0.7rem;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .menu-image {
            flex: 1;
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, #ffedd5, #fed7aa);
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--secondary);
            font-size: 2rem;
            position: relative;
            overflow: hidden;
            flex-shrink: 0;
            transition: all 0.3s;
        }

        .menu-card:hover .menu-image {
            border-radius: 20px;
        }

        .menu-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .menu-badge {
            position: absolute;
            top: 0.3rem;
            right: 0.3rem;
            background: linear-gradient(135deg, var(--secondary), #ea580c);
            color: white;
            padding: 0.2rem 0.5rem;
            border-radius: 100px;
            font-size: 0.6rem;
            font-weight: 600;
            animation: pulse 1.5s infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.05);
            }
        }

        .empty-state {
            text-align: center;
            padding: 3rem;
            color: var(--text-muted);
            grid-column: 1 / -1;
        }

            .empty-state i {
                font-size: 3rem;
                margin-bottom: 1rem;
            }

        /* ==================== TOAST ==================== */
        .toast {
            position: fixed;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%) translateY(200%);
            background: linear-gradient(135deg, var(--primary), #1e1b4b);
            color: white;
            padding: 1rem 2rem;
            border-radius: 50px;
            box-shadow: 0 20px 35px -10px rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            gap: 0.8rem;
            z-index: 3000;
            transition: transform 0.3s ease-out;
        }

            .toast.show {
                transform: translateX(-50%) translateY(0);
            }

            .toast i {
                color: var(--secondary);
                font-size: 1.2rem;
            }

        /* ==================== RESPONSIVIDADE ==================== */
        @@media (max-width: 768px) {
            .hero h2 {
                font-size: 1.5rem;
            }

            .menu-grid {
                grid-template-columns: 1fr;
                padding: 1rem;
            }

            .menu-card {
                flex-direction: row;
                align-items: center;
                gap: 0.8rem;
                padding: 0.8rem;
            }

            .menu-info {
                flex: 2;
            }

            .menu-image {
                width: 80px;
                height: 80px;
                flex-shrink: 0;
                order: 2;
            }

            .menu-header h3 {
                font-size: 1rem;
            }

            .menu-price {
                font-size: 1rem;
            }

            .menu-description {
                font-size: 0.75rem;
                -webkit-line-clamp: 2;
            }
        }

        @@media (max-width: 480px) {
            .app-bar {
                padding: 0.8rem 1rem;
            }

            .app-title h1 {
                font-size: 1rem;
            }

            .establishment-photo {
                width: 40px;
                height: 40px;
            }

            .hero {
                padding: 1.5rem 1rem;
            }

                .hero h2 {
                    font-size: 1.2rem;
                }

                .hero p {
                    font-size: 0.9rem;
                }

            .search-container {
                padding: 0 1rem;
            }

            .search-bar {
                padding: 0.9rem 0.9rem 0.9rem 3rem;
                font-size: 0.9rem;
            }

            .categories {
                padding: 0 1rem 0.8rem;
            }

            .category-chip {
                padding: 0.5rem 1rem;
                font-size: 0.8rem;
                margin-right: 0.6rem;
            }

            .menu-card {
                padding: 0.6rem;
                gap: 0.6rem;
            }

            .menu-image {
                width: 70px;
                height: 70px;
            }

            .menu-header h3 {
                font-size: 0.9rem;
            }

            .menu-price {
                font-size: 0.9rem;
            }

            .menu-description {
                font-size: 0.7rem;
                -webkit-line-clamp: 2;
            }
        }
    </style>
</head>
<body>

    <div class="app-bar">
        <div class="app-title" onclick="window.location.href='/Admin/Pedidos'">
            <div class="establishment-photo">
                @if (estabelecimento != null && !string.IsNullOrEmpty(estabelecimento.Img_Estabelecimento))
                {
                    <img src="@estabelecimento.Img_Estabelecimento" alt="Foto do estabelecimento">
                }
                else
                {
                    <i class="fas fa-store"></i>
                }
            </div>
            <h1>Visualizar Cardápio</h1>
        </div>
        <button class="back-btn" onclick="window.location.href='/Editar/Editar'">
            <i class="fas fa-arrow-left"></i>
        </button>
    </div>

    <div class="hero">
        <h2>@(estabelecimento?.Nome_Estabelecimento ?? "Nosso Cardápio")</h2>
        <p>@(estabelecimento?.MensagemHero ?? "Confira nossos deliciosos espetinhos e jantinhas 🍖")</p>
    </div>

    <div class="search-container">
        <i class="fas fa-search search-icon"></i>
        <input type="text" class="search-bar" placeholder="Buscar no cardápio..." id="searchInput" onkeyup="buscarProdutos()">
    </div>

    <div class="categories" id="categories">
        <span class="category-chip active" data-categoria="todos" onclick="filtrarCategoria('todos', this)">Todos</span>
        @foreach (var categoria in Model.Categorias)
        {
            <span class="category-chip" data-categoria="@categoria.Id_Categoria" onclick="filtrarCategoria('@categoria.Id_Categoria', this)">
                @categoria.Nome_Categoria
            </span>
        }
    </div>

    <div class="menu-grid" id="menuGrid">
        @if (Model.Categorias != null && Model.Categorias.Any())
        {
            @foreach (var categoria in Model.Categorias)
            {
                @if (categoria.Produtos != null && categoria.Produtos.Any())
                {
                    @foreach (var produto in categoria.Produtos)
                    {
                        <div class="menu-card" data-categoria="@categoria.Id_Categoria" data-nome="@produto.Nome_Produto.ToLower()">
                            <div class="menu-info">
                                <div class="menu-header">
                                    <h3>@produto.Nome_Produto</h3>
                                    <div class="menu-price">R$ @produto.Valor_Produto.ToString("F2")</div>
                                </div>
                                <p class="menu-description">@(string.IsNullOrEmpty(produto.Descricao_Produto) ? "Sem descrição" : produto.Descricao_Produto)</p>
                                <div class="menu-footer">
                                    <span class="menu-category">
                                        <i class="fas fa-tag"></i> @categoria.Nome_Categoria
                                    </span>
                                </div>
                            </div>
                            <div class="menu-image">
                                @if (!string.IsNullOrEmpty(produto.Img_Produto))
                                {
                                    <img src="@produto.Img_Produto" alt="@produto.Nome_Produto">
                                }
                                else
                                {
                                    <i class="fas fa-hamburger"></i>
                                }
                                @if (produto.Nome_Produto.Contains("Filé") || produto.Nome_Produto.Contains("Contra"))
                                {
                                    <span class="menu-badge">🔥 Mais vendido</span>
                                }
                            </div>
                        </div>
                    }
                }
            }
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-folder-open"></i>
                <h3>Nenhum produto cadastrado</h3>
                <p>Clique em "Editar Cardápio" no menu lateral para adicionar produtos</p>
            </div>
        }
    </div>

    <div class="toast" id="toast">
        <i class="fas fa-info-circle"></i>
        <span id="toastMessage">Visualização apenas</span>
    </div>

    <script>
        // ==================== VARIÁVEIS ====================
        let currentCategoria = 'todos';
        let toastTimeout;

        // ==================== FILTROS ====================
        function filtrarCategoria(categoria, element) {
            currentCategoria = categoria;
            document.querySelectorAll('.category-chip').forEach(chip => chip.classList.remove('active'));
            if (element) element.classList.add('active');
            aplicarFiltro();
        }

        function buscarProdutos() {
            aplicarFiltro();
        }

        function aplicarFiltro() {
            const termo = document.getElementById('searchInput')?.value.toLowerCase() || '';
            const cards = document.querySelectorAll('.menu-card');

            cards.forEach(card => {
                const cardCategoria = card.getAttribute('data-categoria');
                const cardNome = card.getAttribute('data-nome');

                const matchCategoria = currentCategoria === 'todos' || cardCategoria === currentCategoria;
                const matchBusca = !termo || (cardNome && cardNome.includes(termo));

                card.style.display = (matchCategoria && matchBusca) ? 'flex' : 'none';
            });
        }

        // ==================== TOAST ====================
        function showToast(message, type = 'info') {
            const toast = document.getElementById('toast');
            if (!toast) return;

            const icon = toast.querySelector('i');
            if (icon) {
                icon.className = type === 'success' ? 'fas fa-check-circle' : type === 'error' ? 'fas fa-exclamation-circle' : 'fas fa-info-circle';
            }
            const msgSpan = document.getElementById('toastMessage');
            if (msgSpan) msgSpan.textContent = message;

            if (toastTimeout) clearTimeout(toastTimeout);

            toast.classList.add('show');
            toastTimeout = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

                // ==================== CARREGAR DADOS DO ESTABELECIMENTO ====================
        async function carregarDadosEstabelecimento() {
            try {
                const response = await fetch('/Estabelecimento/ObterDaSessao');
                const data = await response.json();

                if (data.success && data.existe) {
                    const appTitle = document.querySelector('.app-title h1');
                    const photoImg = document.querySelector('.establishment-photo img');
                    const photoIcon = document.querySelector('.establishment-photo i');
                    const heroMessage = document.querySelector('.hero p');
                    const heroTitle = document.querySelector('.hero h2');

                    if (appTitle && data.nome && appTitle.textContent === 'Visualizar Cardápio') {
                        // Mantém o título "Visualizar Cardápio"
                    }

                    if (data.imagem && data.imagem !== '') {
                        if (photoImg) {
                            photoImg.src = data.imagem;
                            photoImg.style.display = 'block';
                            if (photoIcon) photoIcon.style.display = 'none';
                        }
                    } else if (photoIcon) {
                        photoIcon.style.display = 'flex';
                        if (photoImg) photoImg.style.display = 'none';
                    }

                    if (heroTitle && data.nome && heroTitle.textContent === 'Nosso Cardápio') {
                        heroTitle.textContent = data.nome;
                    }

                    if (heroMessage && data.mensagemHero && heroMessage.textContent === 'Confira nossos deliciosos espetinhos e jantinhas 🍖') {
                        heroMessage.textContent = data.mensagemHero;
                    }
                }
            } catch (error) {
                console.error('Erro ao carregar dados do estabelecimento:', error);
            }
        }

        // Ampliar foto ao clicar
        function ampliarFotoEstabelecimento() {
            const photoImg = document.querySelector('.establishment-photo img');
            if (photoImg && photoImg.src && !photoImg.src.includes('via.placeholder.com')) {
                const modal = document.createElement('div');
                modal.style.position = 'fixed';
                modal.style.top = '0';
                modal.style.left = '0';
                modal.style.width = '100%';
                modal.style.height = '100%';
                modal.style.background = 'rgba(0,0,0,0.9)';
                modal.style.zIndex = '5000';
                modal.style.display = 'flex';
                modal.style.alignItems = 'center';
                modal.style.justifyContent = 'center';
                modal.style.cursor = 'pointer';
                modal.innerHTML = `<img src="${photoImg.src}" style="max-width: 90%; max-height: 90%; border-radius: 20px; box-shadow: 0 0 50px rgba(0,0,0,0.5);">`;
                modal.onclick = () => modal.remove();
                document.body.appendChild(modal);
            }
        }

                // ==================== EVENT LISTENERS ====================
        document.querySelector('.establishment-photo')?.addEventListener('click', function(e) {
            e.stopPropagation();
            ampliarFotoEstabelecimento();
        });

        // ==================== INICIALIZAR ====================
        document.addEventListener('DOMContentLoaded', function() {
            aplicarFiltro();
            carregarDadosEstabelecimento();  // ← Adicionar esta linha
            showToast('👀 Modo de visualização - Apenas leitura', 'info');
        });
    </script>
</body>
</html>