<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Alfa Prime • Recuperar Senha</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #0f172a;
            --primary-light: #1e293b;
            --secondary: #f97316;
            --secondary-light: #fb923c;
            --accent: #06b6d4;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;

            --bg-light: #f8fafc;
            --bg-dark: #0b1120;
            --card-bg: #ffffff;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;

            --border-light: #e2e8f0;
            --border-focus: #f97316;

            --shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
            --shadow: 0 10px 40px -15px rgba(0,0,0,0.2);
            --shadow-lg: 0 25px 50px -12px rgba(0,0,0,0.25);
            --shadow-xl: 0 35px 60px -15px rgba(0,0,0,0.3);

            --radius-sm: 12px;
            --radius: 20px;
            --radius-lg: 32px;
            --radius-xl: 40px;

            --transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, var(--primary), #1a2a4a);
            color: var(--text-primary);
            line-height: 1.5;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        /* Elementos decorativos de fundo */
        .bg-decoration {
            position: absolute;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: 0;
        }

        .bg-circle {
            position: absolute;
            border-radius: 50%;
            background: rgba(249, 115, 22, 0.03);
            animation: float 20s ease-in-out infinite;
        }

        .circle1 {
            width: 300px;
            height: 300px;
            top: -150px;
            right: -150px;
            background: rgba(249, 115, 22, 0.05);
        }

        .circle2 {
            width: 400px;
            height: 400px;
            bottom: -200px;
            left: -200px;
            background: rgba(249, 115, 22, 0.03);
            animation-delay: -5s;
        }

        .circle3 {
            width: 200px;
            height: 200px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(249, 115, 22, 0.02);
            animation: pulse 8s ease-in-out infinite;
        }

        @@keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(5deg); }
        }

        @@keyframes pulse {
            0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.02; }
            50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.03; }
        }

        /* Container Principal - Centralizado */
        .recovery-wrapper {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 450px;
            margin: 0 auto;
            padding: 1.5rem;
            animation: fadeInScale 0.6s ease-out;
        }

        @@keyframes fadeInScale {
            from {
                opacity: 0;
                transform: scale(0.95);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        /* Card de Recuperação */
        .recovery-card {
            background: var(--card-bg);
            border-radius: var(--radius-xl);
            padding: 2.5rem 2rem;
            box-shadow: var(--shadow-xl);
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            position: relative;
            overflow: hidden;
        }

        .recovery-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, var(--secondary), #fb923c, var(--secondary));
            animation: gradientShift 3s ease infinite;
        }

        .recovery-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at top right, rgba(249, 115, 22, 0.05), transparent 70%);
            pointer-events: none;
        }

        @@keyframes gradientShift {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        /* Botão Voltar */
        .back-button {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.95rem;
            margin-bottom: 1.5rem;
            transition: var(--transition);
            position: relative;
            z-index: 1;
        }

        .back-button i {
            transition: transform 0.3s ease;
        }

        .back-button:hover {
            color: var(--secondary);
        }

        .back-button:hover i {
            transform: translateX(-5px);
        }

        /* Logo */
        .logo-container {
            text-align: center;
            margin-bottom: 2rem;
            position: relative;
            z-index: 1;
        }

        .logo-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--secondary), #ea580c);
            border-radius: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            color: white;
            font-size: 2rem;
            box-shadow: 0 20px 30px -10px rgba(249, 115, 22, 0.3);
            animation: bounce 3s ease-in-out infinite;
        }

        @@keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }

        .logo-text {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--primary);
            letter-spacing: -1px;
        }

        .logo-text span {
            color: var(--secondary);
        }

        /* Título */
        .recovery-title {
            text-align: center;
            margin-bottom: 2rem;
            position: relative;
            z-index: 1;
        }

        .recovery-title h2 {
            font-size: 1.8rem;
            color: var(--primary);
            margin-bottom: 0.5rem;
            font-weight: 600;
        }

        .recovery-title p {
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.6;
        }

        /* Formulário */
        .form-group {
            margin-bottom: 1.5rem;
            position: relative;
            z-index: 1;
        }

        .form-label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 0.75rem;
            font-size: 0.95rem;
        }

        .form-label i {
            color: var(--secondary);
            font-size: 1rem;
        }

        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 1.2rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 1.2rem;
            transition: var(--transition);
            z-index: 2;
        }

        .form-input {
            width: 100%;
            padding: 1.2rem 1.2rem 1.2rem 3rem;
            border: 2px solid var(--border-light);
            border-radius: var(--radius);
            font-size: 1rem;
            transition: var(--transition);
            background: var(--bg-light);
            position: relative;
            z-index: 1;
        }

        .form-input:focus {
            outline: none;
            border-color: var(--secondary);
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.1);
            background: white;
            transform: translateY(-2px);
        }

        .form-input::placeholder {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* Botão de recuperação */
        .btn-recovery {
            width: 100%;
            background: linear-gradient(135deg, var(--secondary), #ea580c);
            color: white;
            border: none;
            padding: 1.2rem;
            border-radius: var(--radius);
            font-size: 1.2rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            box-shadow: 0 10px 20px -5px rgba(249, 115, 22, 0.3);
            margin: 1.5rem 0 1rem;
            position: relative;
            z-index: 1;
            overflow: hidden;
        }

        .btn-recovery::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s ease;
        }

        .btn-recovery:hover:not(:disabled) {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px -5px rgba(249, 115, 22, 0.4);
        }

        .btn-recovery:hover:not(:disabled)::before {
            left: 100%;
        }

        .btn-recovery:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

        .btn-recovery i {
            font-size: 1.2rem;
            transition: transform 0.3s ease;
        }

        .btn-recovery:hover:not(:disabled) i {
            transform: translateX(5px);
        }

        /* Loading spinner */
        .spinner {
            width: 24px;
            height: 24px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-top: 3px solid white;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Alertas */
        .alert {
            padding: 1rem 1.2rem;
            border-radius: var(--radius-sm);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            animation: slideDownCenter 0.3s ease;
            position: relative;
            z-index: 1;
        }

        @@keyframes slideDownCenter {
            from {
                opacity: 0;
                transform: translateY(-10px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .alert-success {
            background: #f0fdf4;
            border-left: 4px solid var(--success);
            color: #166534;
            border-radius: var(--radius);
        }

        .alert-error {
            background: #fef2f2;
            border-left: 4px solid var(--danger);
            color: #991b1b;
            border-radius: var(--radius);
        }

        .alert-info {
            background: #eff6ff;
            border-left: 4px solid var(--accent);
            color: #1e40af;
            border-radius: var(--radius);
        }

        .alert i {
            font-size: 1.2rem;
        }

        /* Instruções */
        .instructions {
            background: var(--bg-light);
            border-radius: var(--radius);
            padding: 1.2rem;
            margin: 1.5rem 0;
            display: flex;
            gap: 1rem;
            align-items: flex-start;
            border: 1px solid var(--border-light);
            position: relative;
            z-index: 1;
        }

        .instructions i {
            color: var(--secondary);
            font-size: 1.3rem;
            margin-top: 0.1rem;
        }

        .instructions-content p {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }

        .instructions-content p:last-child {
            margin-bottom: 0;
        }

        .instructions-content strong {
            color: var(--primary);
        }

        /* Links */
        .recovery-footer {
            text-align: center;
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid var(--border-light);
            position: relative;
            z-index: 1;
        }

        .recovery-footer p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        .recovery-footer a {
            color: var(--secondary);
            text-decoration: none;
            font-weight: 600;
            transition: var(--transition);
            position: relative;
        }

        .recovery-footer a::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 100%;
            height: 1px;
            background: var(--secondary);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }

        .recovery-footer a:hover {
            color: #ea580c;
        }

        .recovery-footer a:hover::after {
            transform: scaleX(1);
        }

        /* Loading bar */
        .loading-bar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(90deg, var(--secondary), var(--accent));
            animation: loading 1.5s ease-in-out infinite;
            display: none;
            z-index: 2000;
        }

        @@keyframes loading {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }

        /* Responsividade */
        @@media (max-width: 768px) {
            .recovery-wrapper {
                padding: 1rem;
            }

            .recovery-card {
                padding: 2rem 1.5rem;
            }

            .logo-icon {
                width: 70px;
                height: 70px;
                font-size: 1.8rem;
            }

            .logo-text {
                font-size: 1.6rem;
            }

            .recovery-title h2 {
                font-size: 1.5rem;
            }

            .form-input {
                padding: 1rem 1rem 1rem 2.8rem;
                font-size: 0.95rem;
            }

            .btn-recovery {
                padding: 1rem;
                font-size: 1.1rem;
            }
        }

        @@media (max-width: 480px) {
            .recovery-card {
                padding: 1.5rem 1.2rem;
            }

            .logo-icon {
                width: 60px;
                height: 60px;
                font-size: 1.5rem;
            }

            .logo-text {
                font-size: 1.4rem;
            }

            .recovery-title h2 {
                font-size: 1.3rem;
            }

            .recovery-title p {
                font-size: 0.9rem;
            }

            .form-label {
                font-size: 0.9rem;
            }

            .instructions {
                flex-direction: column;
                text-align: center;
                gap: 0.5rem;
            }

            .instructions i {
                margin: 0 auto;
            }

            .alert {
                padding: 0.8rem 1rem;
                font-size: 0.9rem;
            }
        }

        /* Estados */
        .success-state {
            text-align: center;
            padding: 1rem 0;
        }

        .success-state i {
            font-size: 4rem;
            color: var(--success);
            margin-bottom: 1rem;
            animation: scaleIn 0.5s ease;
        }

        @@keyframes scaleIn {
            from {
                transform: scale(0);
            }
            to {
                transform: scale(1);
            }
        }

        .success-state h3 {
            font-size: 1.5rem;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .success-state p {
            color: var(--text-muted);
            margin-bottom: 1.5rem;
        }
    </style>
</head>
<body>
    <!-- Elementos decorativos de fundo -->
    <div class="bg-decoration">
        <div class="bg-circle circle1"></div>
        <div class="bg-circle circle2"></div>
        <div class="bg-circle circle3"></div>
    </div>

    <div class="loading-bar" id="loadingBar"></div>

    <!-- Wrapper centralizado -->
    <div class="recovery-wrapper">
        <div class="recovery-card">
            <!-- Botão Voltar -->
            <a asp-controller="Login" asp-action="Login" class="back-button">
                <i class="fas fa-arrow-left"></i>
                Voltar para o login
            </a>

            <!-- Logo -->
            <div class="logo-container">
                <div class="logo-icon">
                    <i class="fas fa-key"></i>
                </div>
                <div class="logo-text">
                    Alfa<span>Prime</span>
                </div>
            </div>

            <!-- Título -->
            <div class="recovery-title">
                <h2>Recuperar senha</h2>
                <p>Digite seu e-mail para receber as instruções de recuperação</p>
            </div>

            <!-- Container de estados (form/success) -->
            <div id="stateContainer">
                <!-- Estado 1: Formulário de recuperação -->
                <div id="formState">
                    <!-- Alertas -->
                    <div id="alertContainer"></div>

                    <!-- Formulário -->
                    <form id="recoveryForm" onsubmit="handleRecovery(event)">
                        <!-- Email -->
                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-envelope"></i>
                                E-mail cadastrado
                            </label>
                            <div class="input-wrapper">
                                <i class="fas fa-user input-icon"></i>
                                <input type="email" 
                                       id="emailInput"
                                       class="form-input" 
                                       placeholder="admin@alfaprime.com"
                                       value="admin@alfaprime.com"
                                       required>
                            </div>
                        </div>

                        <!-- Instruções -->
                        <div class="instructions">
                            <i class="fas fa-info-circle"></i>
                            <div class="instructions-content">
                                <p>Enviaremos um link para <strong>redefinir sua senha</strong> no e-mail informado.</p>
                                <p>O link é válido por <strong>24 horas</strong>.</p>
                            </div>
                        </div>

                        <!-- Botão -->
                        <button type="submit" class="btn-recovery" id="recoveryButton">
                            <span>Enviar instruções</span>
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </form>
                </div>

                <!-- Estado 2: Sucesso (inicialmente escondido) -->
                <div id="successState" style="display: none;">
                    <div class="success-state">
                        <i class="fas fa-check-circle"></i>
                        <h3>E-mail enviado!</h3>
                        <p>Enviamos as instruções de recuperação para:</p>
                        <p style="font-weight: 600; color: var(--primary);" id="sentEmailDisplay">admin@alfaprime.com</p>
                        
                        <div class="instructions" style="margin-top: 2rem; text-align: left;">
                            <i class="fas fa-envelope-open-text"></i>
                            <div class="instructions-content">
                                <p>📧 <strong>Verifique sua caixa de entrada</strong> e a pasta de spam.</p>
                                <p>⏱️ O link expira em <strong>24 horas</strong>.</p>
                                <p>🔄 Não recebeu? <a href="#" onclick="reenviarEmail(event)" style="color: var(--secondary);">Reenviar e-mail</a></p>
                            </div>
                        </div>

                        <a href="login.html" class="btn-recovery" style="margin-top: 2rem; text-decoration: none;">
                            <i class="fas fa-arrow-left"></i>
                            Voltar para o login
                        </a>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="recovery-footer">
                <p>Lembrou sua senha? <a asp-controller="Login" asp-action="Login">Fazer login</a></p>
            </div>
        </div>
    </div>

    <script>
        // Elementos DOM
        const emailInput = document.getElementById('emailInput');
        const recoveryButton = document.getElementById('recoveryButton');
        const alertContainer = document.getElementById('alertContainer');
        const loadingBar = document.getElementById('loadingBar');
        const formState = document.getElementById('formState');
        const successState = document.getElementById('successState');
        const sentEmailDisplay = document.getElementById('sentEmailDisplay');

        // Mostrar loading
        function showLoading() {
            loadingBar.style.display = 'block';
        }

        function hideLoading() {
            setTimeout(() => {
                loadingBar.style.display = 'none';
            }, 300);
        }

        // Mostrar alerta
        function showAlert(type, message) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type}`;
            alertDiv.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i>
                <span>${message}</span>
            `;
            
            alertContainer.innerHTML = '';
            alertContainer.appendChild(alertDiv);
            
            // Remover alerta após 5 segundos
            setTimeout(() => {
                alertDiv.style.animation = 'slideDownCenter 0.3s reverse';
                setTimeout(() => {
                    if (alertDiv.parentNode) {
                        alertContainer.removeChild(alertDiv);
                    }
                }, 300);
            }, 5000);
        }

        // Validação de email
        function validateEmail(email) {
            const re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            return re.test(email);
        }

        // Handler da recuperação
        async function handleRecovery(event) {
            event.preventDefault();
            
            const email = emailInput.value.trim();
            
            // Validar email
            if (!email) {
                showAlert('error', 'Digite seu e-mail!');
                emailInput.style.borderColor = 'var(--danger)';
                return;
            }
            
            if (!validateEmail(email)) {
                showAlert('error', 'E-mail inválido!');
                emailInput.style.borderColor = 'var(--danger)';
                return;
            }
            
            // Resetar borda
            emailInput.style.borderColor = '';
            
            // Desabilitar botão
            recoveryButton.disabled = true;
            recoveryButton.innerHTML = `
                <div class="spinner"></div>
                <span>Enviando...</span>
            `;
            
            showLoading();
            
            // Simular envio para o servidor
            setTimeout(() => {
                // Verificar se email existe (simulação)
                const existingEmails = ['admin@alfaprime.com', 'teste@alfaprime.com'];
                
                if (existingEmails.includes(email)) {
                    // Sucesso - mostrar estado de sucesso
                    sentEmailDisplay.textContent = email;
                    
                    formState.style.display = 'none';
                    successState.style.display = 'block';
                    
                    showAlert('success', 'Instruções enviadas com sucesso!');
                    
                } else {
                    // Email não encontrado
                    showAlert('error', 'E-mail não encontrado em nossa base de dados!');
                    
                    // Reativar botão
                    recoveryButton.disabled = false;
                    recoveryButton.innerHTML = `
                        <span>Enviar instruções</span>
                        <i class="fas fa-paper-plane"></i>
                    `;
                }
                
                hideLoading();
            }, 2000);
        }

        // Função para reenviar email
        function reenviarEmail(event) {
            event.preventDefault();
            
            showLoading();
            
            setTimeout(() => {
                showAlert('success', 'Novo e-mail enviado! Verifique sua caixa de entrada.');
                hideLoading();
            }, 1000);
        }

        // Event listeners
        emailInput.addEventListener('focus', () => {
            emailInput.style.borderColor = '';
        });

        // Enter no campo email também submete
        emailInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter' && formState.style.display !== 'none') {
                handleRecovery(e);
            }
        });

        // Animar elementos ao carregar
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelector('.recovery-card').style.opacity = '0';
            setTimeout(() => {
                document.querySelector('.recovery-card').style.transition = 'opacity 0.5s';
                document.querySelector('.recovery-card').style.opacity = '1';
            }, 100);
        });

        // Prevenir clique em links vazios
        document.querySelectorAll('a[href="#"]').forEach(link => {
            link.addEventListener('click', (e) => e.preventDefault());
        });
    </script>
</body>
</html>