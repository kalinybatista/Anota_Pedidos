@using Anota_Pedidos.Models
@using System.Text.Json
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@model Anota_Pedidos.ViewModels.GerenciarCardapioViewModel
<!-- Adicionar no final do <body> -->
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery antiforgery
@{
    var requestToken = antiforgery.GetAndStoreTokens(Context).RequestToken;
}

@{
    ViewData["Title"] = "Faça seu Pedido";
    Layout = null;

    // Obter estabelecimento da sessão
    var estabelecimentoJson = Context.Session.GetString("Estabelecimento");
    EstabelecimentoSessionDTO estabelecimento = null;

    if (!string.IsNullOrEmpty(estabelecimentoJson))
    {
        estabelecimento = JsonSerializer.Deserialize<EstabelecimentoSessionDTO>(estabelecimentoJson);
    }
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>@(estabelecimento?.Nome_Estabelecimento ?? "Alfa Prime") • Faça seu Pedido</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #0f172a;
            --primary-light: #1e293b;
            --secondary: #f97316;
            --secondary-light: #fb923c;
            --accent: #06b6d4;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --bg-light: #f8fafc;
            --bg-dark: #0b1120;
            --card-bg: #ffffff;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --border-light: #e2e8f0;
            --border-focus: #f97316;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
            --shadow: 0 10px 40px -15px rgba(0,0,0,0.2);
            --shadow-lg: 0 25px 50px -12px rgba(0,0,0,0.25);
            --shadow-xl: 0 35px 60px -15px rgba(0,0,0,0.3);
            --radius-sm: 12px;
            --radius: 20px;
            --radius-lg: 32px;
            --radius-xl: 40px;
            --transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg-light);
            color: var(--text-primary);
            line-height: 1.5;
        }

        /* ==================== APP BAR MODERNA ==================== */
        .app-bar {
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(10px);
            color: white;
            padding: 1rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 40;
            box-shadow: var(--shadow);
        }

        .app-title {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            cursor: pointer;
        }

        .establishment-photo {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            overflow: hidden;
            border: 2px solid var(--secondary);
            cursor: pointer;
            transition: var(--transition);
            background: linear-gradient(135deg, #fff7ed, #ffedd5);
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .establishment-photo:hover {
                transform: scale(1.05);
                box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.3);
            }

            .establishment-photo img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .establishment-photo i {
                font-size: 1.5rem;
                color: var(--secondary);
            }

        .app-title h1 {
            font-size: 1.3rem;
            font-weight: 600;
            letter-spacing: -0.3px;
            background: linear-gradient(135deg, #fff, #f97316);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .cart-btn {
            position: relative;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            width: 44px;
            height: 44px;
            border-radius: 14px;
            font-size: 1.2rem;
            cursor: pointer;
            transition: var(--transition);
        }

            .cart-btn:hover {
                background: rgba(255, 255, 255, 0.2);
                transform: scale(1.05);
            }

        .cart-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: linear-gradient(135deg, var(--secondary), #ea580c);
            color: white;
            font-size: 0.7rem;
            font-weight: 600;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
            animation: pulse 1.5s infinite;
        }

        /* ==================== HERO MODERNO ==================== */
        .hero {
            background: linear-gradient(135deg, var(--primary), #1e1b4b);
            padding: 3rem 1.5rem;
            color: white;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .hero::before {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(249,115,22,0.15) 0%, transparent 70%);
                animation: rotateHero 20s linear infinite;
            }

        @@keyframes rotateHero {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        .hero h2 {
            font-size: 2.2rem;
            margin-bottom: 0.5rem;
            position: relative;
            z-index: 1;
        }

        .hero p {
            opacity: 0.9;
            font-size: 1.1rem;
            position: relative;
            z-index: 1;
        }

        /* ==================== SEARCH MODERNA ==================== */
        .search-container {
            max-width: 600px;
            margin: -1.8rem auto 1.5rem;
            padding: 0 1.5rem;
            position: relative;
            z-index: 10;
        }

        .search-bar {
            width: 100%;
            padding: 1.2rem 1.2rem 1.2rem 3.5rem;
            border: none;
            border-radius: var(--radius-xl);
            font-size: 1rem;
            box-shadow: 0 20px 35px -10px rgba(0,0,0,0.2);
            transition: all 0.3s ease;
        }

            .search-bar:focus {
                outline: none;
                transform: translateY(-2px);
                box-shadow: 0 25px 40px -12px rgba(249,115,22,0.3);
            }

        .search-icon {
            position: absolute;
            left: 2.5rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 1.2rem;
        }

        /* ==================== CATEGORIAS MODERNAS ==================== */
        .categories {
            padding: 0 1.5rem 1rem;
            overflow-x: auto;
            white-space: nowrap;
            scrollbar-width: none;
            -ms-overflow-style: none;
            cursor: grab;
        }

            .categories:active {
                cursor: grabbing;
            }

            .categories::-webkit-scrollbar {
                display: none;
            }

        .category-chip {
            display: inline-block;
            padding: 0.8rem 1.5rem;
            margin-right: 0.8rem;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(5px);
            border: 2px solid var(--border-light);
            border-radius: 100px;
            font-weight: 600;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .category-chip:hover {
                border-color: var(--secondary);
                color: var(--secondary);
                transform: translateY(-2px);
            }

            .category-chip.active {
                background: linear-gradient(135deg, var(--secondary), #ea580c);
                border-color: var(--secondary);
                color: white;
                box-shadow: 0 4px 15px rgba(249,115,22,0.3);
            }

        /* ==================== MENU GRID MODERNO ==================== */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 1.5rem;
            padding: 1.5rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .menu-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            border: 1px solid rgba(255, 255, 255, 0.2);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: row;
            padding: 1rem;
            gap: 1rem;
            position: relative;
            animation: fadeInUp 0.5s ease-out;
            animation-fill-mode: both;
        }

            .menu-card:nth-child(1) {
                animation-delay: 0.05s;
            }

            .menu-card:nth-child(2) {
                animation-delay: 0.1s;
            }

            .menu-card:nth-child(3) {
                animation-delay: 0.15s;
            }

            .menu-card:nth-child(4) {
                animation-delay: 0.2s;
            }

            .menu-card:nth-child(5) {
                animation-delay: 0.25s;
            }

            .menu-card:nth-child(6) {
                animation-delay: 0.3s;
            }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .menu-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.2);
            border-color: var(--secondary);
        }

        .menu-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 50%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s;
        }

        .menu-card:hover::after {
            left: 100%;
        }

        .menu-info {
            flex: 2;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .menu-header {
            margin-bottom: 0.5rem;
        }

            .menu-header h3 {
                font-size: 1.2rem;
                font-weight: 600;
                color: var(--primary);
                margin-bottom: 0.25rem;
            }

        .menu-price {
            font-size: 1.2rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--secondary), #ea580c);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }

        .menu-description {
            color: var(--text-secondary);
            font-size: 0.85rem;
            margin-bottom: 0.8rem;
            line-height: 1.4;
        }

        .menu-footer {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            flex-wrap: wrap;
        }

        .quantity-control {
            display: flex;
            align-items: center;
            gap: 0.3rem;
            background: var(--bg-light);
            border-radius: 100px;
            padding: 0.2rem;
        }

        .qty-btn {
            width: 28px;
            height: 28px;
            border: none;
            background: white;
            border-radius: 50%;
            color: var(--secondary);
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            box-shadow: var(--shadow-sm);
        }

            .qty-btn:hover {
                background: var(--secondary);
                color: white;
                transform: scale(1.1);
            }

        .qty-value {
            font-weight: 600;
            min-width: 28px;
            text-align: center;
        }

        .btn-add {
            background: linear-gradient(135deg, var(--secondary), #ea580c);
            color: white;
            border: none;
            padding: 0.4rem 1rem;
            border-radius: 100px;
            font-weight: 600;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 0.3rem;
            position: relative;
            overflow: hidden;
        }

            .btn-add::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
                transition: left 0.5s;
            }

            .btn-add:hover::before {
                left: 100%;
            }

            .btn-add:hover {
                transform: scale(1.02);
            }

            .btn-add:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }

        .menu-image {
            flex: 1;
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, #ffedd5, #fed7aa);
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--secondary);
            font-size: 2rem;
            position: relative;
            overflow: hidden;
            flex-shrink: 0;
            transition: all 0.3s;
        }

        .menu-card:hover .menu-image {
            border-radius: 20px;
        }

        .menu-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .menu-badge {
            position: absolute;
            top: 0.3rem;
            right: 0.3rem;
            background: linear-gradient(135deg, var(--secondary), #ea580c);
            color: white;
            padding: 0.2rem 0.5rem;
            border-radius: 100px;
            font-size: 0.6rem;
            font-weight: 600;
            animation: pulse 1.5s infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.05);
            }
        }

        /* ==================== CARRINHO MODERNO ==================== */
        .cart-sidebar {
            position: fixed;
            top: 0;
            right: -400px;
            width: 100%;
            max-width: 400px;
            height: 100vh;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            box-shadow: var(--shadow-xl);
            transition: right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }

            .cart-sidebar.show {
                right: 0;
            }

        .cart-header {
            background: linear-gradient(135deg, var(--primary), #1e1b4b);
            color: white;
            padding: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-shrink: 0; /* Impede o header de encolher */
        }

            .cart-header h2 {
                font-size: 1.3rem;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

        .cart-close {
            background: rgba(255, 255, 255, 0.2);
            border: none;
            color: white;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            cursor: pointer;
            transition: var(--transition);
        }

            .cart-close:hover {
                background: rgba(255, 255, 255, 0.3);
                transform: rotate(90deg);
            }

        /* Área dos itens do carrinho - COM SCROLL */
        .cart-items {
            flex: 1;
            overflow-y: auto; /* Scroll vertical */
            overflow-x: hidden; /* Esconde scroll horizontal */
            padding: 1rem 1.5rem;
            max-height: calc(100vh - 180px); /* Altura máxima ajustável */
            min-height: 200px;
        }

            /* Personalizar scrollbar */
            .cart-items::-webkit-scrollbar {
                width: 6px;
            }

            .cart-items::-webkit-scrollbar-track {
                background: var(--border-light);
                border-radius: 10px;
            }

            .cart-items::-webkit-scrollbar-thumb {
                background: var(--secondary);
                border-radius: 10px;
            }

                .cart-items::-webkit-scrollbar-thumb:hover {
                    background: #ea580c;
                }

        .cart-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem;
            border-bottom: 1px solid var(--border-light);
            transition: all 0.3s ease;
            border-radius: 12px;
        }

            .cart-item:hover {
                background: rgba(249,115,22,0.05);
                transform: translateX(5px);
            }

        .cart-item-info {
            flex: 1;
        }

            .cart-item-info h4 {
                font-size: 1rem;
                margin-bottom: 0.2rem;
                word-break: break-word; /* Quebra palavras longas */
            }

        .cart-item-price {
            color: var(--secondary);
            font-weight: 600;
            font-size: 0.9rem;
        }

        .cart-item-controls {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex-shrink: 0; /* Impede os controles de encolher */
        }

        .cart-qty-btn {
            width: 28px;
            height: 28px;
            border: 1px solid var(--border-light);
            background: white;
            border-radius: 8px;
            color: var(--text-secondary);
            cursor: pointer;
            transition: var(--transition);
        }

            .cart-qty-btn:hover {
                background: var(--secondary);
                border-color: var(--secondary);
                color: white;
            }

        .cart-item-total {
            font-weight: 600;
            min-width: 60px;
            text-align: right;
            flex-shrink: 0;
        }

        .btn-remove {
            background: transparent;
            border: none;
            color: var(--danger);
            cursor: pointer;
            padding: 0.5rem;
            transition: var(--transition);
            flex-shrink: 0;
        }

            .btn-remove:hover {
                transform: scale(1.2);
            }

        /* Rodapé do carrinho fixo */
        .cart-footer {
            background: var(--bg-light);
            padding: 1.5rem;
            border-top: 2px solid var(--border-light);
            flex-shrink: 0; /* Impede o footer de encolher */
        }

        .cart-total {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            font-size: 1.2rem;
            font-weight: 600;
        }

        .total-value {
            background: linear-gradient(135deg, var(--secondary), #ea580c);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 1.5rem;
        }

        .btn-checkout {
            width: 100%;
            background: linear-gradient(135deg, var(--success), #059669);
            color: white;
            border: none;
            padding: 1rem;
            border-radius: var(--radius);
            font-weight: 600;
            font-size: 1.1rem;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .empty-cart {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-muted);
        }

            .empty-cart i {
                font-size: 4rem;
                margin-bottom: 1rem;
            }

        /* ==================== MODAL MODERNO ==================== */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(5px);
            z-index: 2000;
            justify-content: center;
            align-items: center;
            padding: 1rem;
        }

            .modal.show {
                display: flex;
            }

        .modal-content {
            background: white;
            border-radius: var(--radius-xl);
            width: 100%;
            max-width: 550px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: var(--shadow-xl);
            animation: modalSlideIn 0.3s ease-out;
        }

        @@keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: scale(0.9) translateY(20px);
            }

            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        .modal-header {
            background: linear-gradient(135deg, var(--primary), #1e1b4b);
            color: white;
            padding: 2rem;
            border-radius: var(--radius-xl) var(--radius-xl) 0 0;
            text-align: center;
        }

            .modal-header i {
                font-size: 3rem;
                color: var(--secondary);
                margin-bottom: 1rem;
                animation: bounce 1s ease-in-out;
            }

        @@keyframes bounce {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        .modal-header h2 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
        }

        .modal-body {
            padding: 2rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .form-input {
            width: 100%;
            padding: 1rem 1.2rem;
            border: 2px solid var(--border-light);
            border-radius: var(--radius);
            font-size: 1rem;
            transition: all 0.3s ease;
            background: var(--bg-light);
        }

            .form-input:focus {
                outline: none;
                border-color: var(--secondary);
                box-shadow: 0 0 0 4px #fff7ed;
                transform: translateY(-2px);
            }

        .input-icon {
            position: relative;
        }

            .input-icon i {
                position: absolute;
                left: 1rem;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
            }

            .input-icon input {
                padding-left: 3rem;
            }

        .payment-options {
            display: flex;
            gap: 1rem;
            margin-top: 0.5rem;
            flex-wrap: wrap;
        }

        .payment-option {
            flex: 1;
            min-width: 100px;
            cursor: pointer;
            background: var(--bg-light);
            border: 2px solid var(--border-light);
            border-radius: var(--radius);
            padding: 0.8rem;
            text-align: center;
            transition: var(--transition);
        }

            .payment-option:hover {
                border-color: var(--secondary);
                background: #fff7ed;
                transform: translateY(-2px);
            }

            .payment-option input[type="radio"] {
                accent-color: var(--secondary);
                width: 16px;
                height: 16px;
                margin-right: 0.5rem;
                vertical-align: middle;
            }

            .payment-option i {
                color: var(--secondary);
                margin-right: 0.5rem;
            }

        .modal-footer {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
        }

        .btn {
            flex: 1;
            padding: 1rem;
            border: none;
            border-radius: var(--radius);
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--secondary), #ea580c);
            color: white;
        }

            .btn-primary:hover {
                background: #ea580c;
                transform: translateY(-2px);
                box-shadow: 0 10px 20px -5px var(--secondary);
            }

        .btn-secondary {
            background: var(--bg-light);
            color: var(--text-secondary);
        }

            .btn-secondary:hover {
                background: #e2e8f0;
            }

        /* ==================== LOADING BAR MODERNA ==================== */
        .loading-bar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--secondary), var(--accent), transparent);
            background-size: 200% 100%;
            animation: loadingShine 1.5s ease-in-out infinite;
            display: none;
            z-index: 2000;
        }

        @@keyframes loadingShine {
            0% {
                background-position: -200% 0;
            }

            100% {
                background-position: 200% 0;
            }
        }

        /* ==================== TOAST MODERNO (estilo Meus Pedidos) ==================== */
        .toast {
            position: fixed;
            left: 50%;
            bottom: calc(20px + env(safe-area-inset-bottom));
            transform: translateX(-50%) translateY(30px);
            background: var(--primary);
            color: white;
            padding: 0.85rem 1.2rem;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.7rem;
            width: max-content;
            max-width: calc(100vw - 32px);
            font-size: 0.92rem;
            text-align: center;
            line-height: 1.4;
            box-shadow: 0 10px 25px rgba(0,0,0,0.22);
            z-index: 3000;
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
            transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s ease;
            word-break: break-word;
            overflow-wrap: break-word;
            will-change: transform, opacity;
        }

            .toast.show {
                opacity: 1;
                visibility: visible;
                transform: translateX(-50%) translateY(0);
            }

            .toast i {
                color: var(--secondary);
                font-size: 1.2rem;
                flex-shrink: 0;
            }

        /* Responsivo para celular */
        @@media (max-width: 768px) {
            .toast

        {
            width: calc(100vw - 24px);
            max-width: 420px;
            padding: 0.85rem 1rem;
            font-size: 0.85rem;
            border-radius: 16px;
            bottom: calc(16px + env(safe-area-inset-bottom));
        }

        }

        @@media (max-width: 480px) {
            .toast

        {
            width: calc(100vw - 20px);
            padding: 0.8rem 0.9rem;
            font-size: 0.8rem;
            border-radius: 14px;
            gap: 0.5rem;
        }

        .toast i {
            font-size: 0.9rem;
        }

        }

        /* ==================== RESPONSIVIDADE ==================== */
        @@media (max-width: 768px) {
            .hero h2 {
                font-size: 1.5rem;
            }

            .establishment-photo {
                width: 55px;
                height: 55px;
            }

            .menu-grid {
                grid-template-columns: 1fr;
                padding: 1rem;
            }

            .menu-card {
                flex-direction: row;
                align-items: center;
                gap: 0.8rem;
                padding: 0.8rem;
            }

            .menu-info {
                flex: 2;
            }

            .menu-image {
                width: 80px;
                height: 80px;
                flex-shrink: 0;
                order: 2;
            }

            .menu-header h3 {
                font-size: 1rem;
            }

            .menu-price {
                font-size: 1rem;
                margin-bottom: 0.2rem;
            }

            .menu-description {
                font-size: 0.75rem;
                margin-bottom: 0.5rem;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

            .menu-footer {
                gap: 0.5rem;
                flex-wrap: wrap;
            }

            .quantity-control {
                gap: 0.2rem;
            }

            .qty-btn {
                width: 24px;
                height: 24px;
                font-size: 0.8rem;
            }

            .qty-value {
                min-width: 24px;
                font-size: 0.85rem;
            }

            .btn-add {
                padding: 0.3rem 0.8rem;
                font-size: 0.75rem;
            }

            .cart-sidebar {
                max-width: 100%;
                right: -100%;
            }

                .cart-sidebar.show {
                    right: 0;
                }

            .modal-footer {
                flex-direction: column;
            }

            .payment-options {
                flex-direction: column;
            }

            .payment-option {
                width: 100%;
            }
        }

        @@media (max-width: 480px) {
            .app-bar {
                padding: 0.8rem 1rem;
            }

            .app-title h1 {
                font-size: 1rem;
            }

            .establishment-photo {
                width: 40px;
                height: 40px;
            }

                .establishment-photo i {
                    font-size: 1.2rem;
                }

            .hero {
                padding: 1.5rem 1rem;
            }

                .hero h2 {
                    font-size: 1.2rem;
                }

                .hero p {
                    font-size: 0.9rem;
                }

            .search-container {
                padding: 0 1rem;
            }

            .search-bar {
                padding: 0.9rem 0.9rem 0.9rem 3rem;
                font-size: 0.9rem;
            }

            .categories {
                padding: 0 1rem 0.8rem;
            }

            .category-chip {
                padding: 0.5rem 1rem;
                font-size: 0.8rem;
                margin-right: 0.6rem;
            }

            .menu-card {
                padding: 0.6rem;
                gap: 0.6rem;
            }

            .menu-image {
                width: 70px;
                height: 70px;
            }

            .menu-header h3 {
                font-size: 0.9rem;
            }

            .menu-price {
                font-size: 0.9rem;
            }

            .menu-description {
                font-size: 0.7rem;
                -webkit-line-clamp: 2;
            }

            .quantity-control {
                gap: 0.15rem;
            }

            .qty-btn {
                width: 22px;
                height: 22px;
                font-size: 0.7rem;
            }

            .qty-value {
                min-width: 22px;
                font-size: 0.8rem;
            }

            .btn-add {
                padding: 0.25rem 0.6rem;
                font-size: 0.7rem;
            }
        }

        /* ==================== MODAL DE CONFIRMAÇÃO PERSONALIZADA ==================== */
        .confirm-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(5px);
            z-index: 10000;
            justify-content: center;
            align-items: center;
            animation: fadeIn 0.3s ease;
        }

            .confirm-modal.show {
                display: flex;
            }

        .confirm-content {
            background: linear-gradient(135deg, #fff, #fff7ed);
            border-radius: 32px;
            max-width: 400px;
            width: 90%;
            padding: 0;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            animation: slideUp 0.3s ease-out;
            overflow: hidden;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .confirm-header {
            background: linear-gradient(135deg, #0f172a, #1e1b4b);
            color: white;
            padding: 2rem;
            text-align: center;
        }

            .confirm-header i {
                font-size: 4rem;
                color: #10b981;
                margin-bottom: 1rem;
                animation: bounce 0.5s ease;
            }

        @@keyframes bounce {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.2);
            }
        }

        .confirm-header h2 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
        }

        .confirm-header p {
            opacity: 0.9;
            font-size: 0.9rem;
        }

        .confirm-body {
            padding: 2rem;
            text-align: center;
        }

            .confirm-body .pedido-number {
                font-size: 2.5rem;
                font-weight: 800;
                background: linear-gradient(135deg, #f97316, #ea580c);
                background-clip: text;
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                margin: 1rem 0;
            }

            .confirm-body .pedido-info {
                color: #475569;
                margin: 1rem 0;
                font-size: 1rem;
            }

        .confirm-footer {
            display: flex;
            gap: 1rem;
            padding: 1.5rem;
            background: #f8fafc;
            border-top: 1px solid #e2e8f0;
        }

        .confirm-btn {
            flex: 1;
            padding: 1rem;
            border: none;
            border-radius: 60px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .confirm-btn-primary {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
        }

            .confirm-btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px -5px #10b981;
            }

        .confirm-btn-secondary {
            background: #e2e8f0;
            color: #475569;
        }

            .confirm-btn-secondary:hover {
                background: #cbd5e1;
                transform: translateY(-2px);
            }

        /* Confete animado */
        .confetti {
            position: fixed;
            width: 10px;
            height: 20px;
            background: linear-gradient(135deg, #f97316, #10b981);
            position: absolute;
            top: -20px;
            animation: fall 3s linear forwards;
        }

        @@keyframes fall {
            to {
                transform: translateY(100vh) rotate(360deg);
                opacity: 0;
            }
        }

        /* Feedback visual para campo de telefone */
        #clienteTelefone {
            transition: border-color 0.3s ease;
        }

            #clienteTelefone:valid {
                border-color: #10b981;
            }

            #clienteTelefone:invalid {
                border-color: #ef4444;
            }
    </style>
</head>
<body>
    <div class="loading-bar" id="loadingBar"></div>

    <div class="app-bar">
        <div class="app-title" onclick="window.location.href='/Usuario/Cardapio'">
            <div class="establishment-photo">
                @if (estabelecimento != null && !string.IsNullOrEmpty(estabelecimento.Img_Estabelecimento))
                {
                    <img src="@estabelecimento.Img_Estabelecimento" alt="Foto do estabelecimento">
                }
                else
                {
                    <i class="fas fa-store"></i>
                }
            </div>
            <h1>@(estabelecimento?.Nome_Estabelecimento ?? "Alfa Prime")</h1>
        </div>
        <button class="cart-btn" onclick="toggleCart()">
            <i class="fas fa-shopping-bag"></i>
            <span class="cart-badge" id="cartBadge">0</span>
        </button>
    </div>

    <div style="position: fixed; bottom: 2rem; left: 1rem; z-index: 100;">
        <button onclick="verMeusPedidos()" style="background: linear-gradient(135deg, var(--secondary), #ea580c); border: none; color: white; width: 50px; height: 50px; border-radius: 50%; box-shadow: 0 4px 15px rgba(0,0,0,0.2); cursor: pointer;">
            <i class="fas fa-clipboard-list" style="font-size: 1.2rem;"></i>
        </button>
    </div>

    <div class="hero">
        <h2>Faça seu Pedido</h2>
        <p>@(estabelecimento?.MensagemHero ?? "Espetinhos e jantinhas feitos com amor ❤️")</p>
    </div>

    <br />

    <div class="search-container">
        <i class="fas fa-search search-icon"></i>
        <input type="text" class="search-bar" placeholder="Buscar no cardápio..." id="searchInput" onkeyup="buscarProdutos()">
    </div>

    <div class="categories" id="categories">
        <span class="category-chip active" data-categoria="todos" onclick="filtrarCategoria('todos', this)">Todos</span>
        @foreach (var categoria in Model.Categorias)
        {
            <span class="category-chip" data-categoria="@categoria.Id_Categoria" onclick="filtrarCategoria('@categoria.Id_Categoria', this)">
                @categoria.Nome_Categoria
            </span>
        }
    </div>

    <div class="menu-grid" id="menuGrid">
        @if (Model.Categorias != null && Model.Categorias.Any())
        {
            @foreach (var categoria in Model.Categorias)
            {
                @if (categoria.Produtos != null && categoria.Produtos.Any())
                {
                    @foreach (var produto in categoria.Produtos)
                    {
                        <div class="menu-card" data-categoria="@categoria.Id_Categoria" data-nome="@produto.Nome_Produto.ToLower()">
                            <div class="menu-info">
                                <div class="menu-header">
                                    <h3>@produto.Nome_Produto</h3>
                                    <div class="menu-price">R$ @produto.Valor_Produto.ToString("F2")</div>
                                </div>
                                <p class="menu-description">@(string.IsNullOrEmpty(produto.Descricao_Produto) ? "" : produto.Descricao_Produto)</p>
                                <div class="menu-footer">
                                    <div class="quantity-control">
                                        <button class="qty-btn" onclick="diminuirQtd(@produto.Id_Produto)">-</button>
                                        <span class="qty-value" id="qtd-@produto.Id_Produto">0</span>
                                        <button class="qty-btn" onclick="aumentarQtd(@produto.Id_Produto)">+</button>
                                    </div>
                                    <button class="btn-add" onclick="adicionarAoCarrinho(@produto.Id_Produto)" id="btn-@produto.Id_Produto" disabled>
                                        <i class="fas fa-plus"></i> Adicionar
                                    </button>
                                </div>
                            </div>
                            <div class="menu-image">
                                @if (!string.IsNullOrEmpty(produto.Img_Produto))
                                {
                                    <img src="@produto.Img_Produto" alt="@produto.Nome_Produto">
                                }
                                else
                                {
                                    <i class="fas fa-hamburger"></i>
                                }
                                @if (produto.Nome_Produto.Contains("Filé") || produto.Nome_Produto.Contains("Contra"))
                                {
                                    <span class="menu-badge">🔥 Mais vendido</span>
                                }
                            </div>
                        </div>
                    }
                }
            }
        }
        else
        {
            <div class="empty-state" style="text-align: center; padding: 3rem; grid-column: 1 / -1;">
                <i class="fas fa-hamburger" style="font-size: 3rem; color: var(--text-muted);"></i>
                <h3 style="margin-top: 1rem;">Nenhum produto cadastrado</h3>
                <p>Volte mais tarde para ver nosso cardápio!</p>
            </div>
        }

        <br>
    </div>



    <div class="cart-overlay" id="cartOverlay" onclick="toggleCart()"></div>

    <div class="cart-sidebar" id="cartSidebar">
        <div class="cart-header">
            <h2><i class="fas fa-shopping-bag"></i> Meu Pedido</h2>
            <button class="cart-close" onclick="toggleCart()"><i class="fas fa-times"></i></button>
        </div>
        <div class="cart-items" id="cartItems">
            <div class="empty-cart"><i class="fas fa-shopping-basket"></i><h3>Carrinho vazio</h3><p>Adicione itens do cardápio</p></div>
        </div>
        <div class="cart-footer" id="cartFooter" style="display: none;">
            <div class="cart-total"><span>Total</span><span class="total-value" id="cartTotal">R$ 0,00</span></div>
            <button class="btn-checkout" onclick="abrirModalIdentificacao()"><i class="fas fa-check-circle"></i> Finalizar Pedido</button>
        </div>
    </div>

    <!-- Modal de Identificação -->
    <div class="modal" id="identificacaoModal">
        <div class="modal-content">
            <div class="modal-header">
                <i class="fas fa-user-circle"></i>
                <h2>Quase lá!</h2>
                <p>Identifique-se e escolha o pagamento</p>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Seu Nome</label>
                    <div class="input-icon"><i class="fas fa-user"></i><input type="text" class="form-input" id="clienteNome" placeholder="Ex: João Silva"></div>
                </div>
                <div class="form-group">
                    <label class="form-label">Número</label>
                    <div class="input-icon"><i class="fas fa-phone"></i><input type="tel" class="form-input" id="clienteTelefone" placeholder="(11) 99999-9999"></div>
                    <small>Para Melhor Identificação </small>
                </div>

                <!-- Tipo de Pedido -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-shopping-bag"></i>
                        Tipo de Pedido
                    </label>
                    <div class="payment-options">
                        <label class="payment-option">
                            <input type="radio" name="tipoPedido" value="CONSUMIR" checked>
                            <i class="fas fa-utensils"></i> Comer no local
                        </label>
                        <label class="payment-option">
                            <input type="radio" name="tipoPedido" value="ENTREGAR">
                            <i class="fas fa-shopping-bag"></i> Para levar
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Forma de Pagamento</label>
                    <div class="payment-options">
                        <label class="payment-option">
                            <input type="radio" name="formaPagamento" value="DINHEIRO" checked>
                            <i class="fas fa-money-bill"></i> Dinheiro
                        </label>
                        <label class="payment-option">
                            <input type="radio" name="formaPagamento" value="PIX">
                            <i class="fas fa-qrcode"></i> PIX
                        </label>
                        <label class="payment-option">
                            <input type="radio" name="formaPagamento" value="CARTÃO">
                            <i class="fas fa-credit-card"></i> Cartão
                        </label>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" onclick="fecharModal()"><i class="fas fa-times"></i> Voltar</button>
                    <button class="btn btn-primary" onclick="finalizarPedido()"><i class="fas fa-check-circle"></i> Confirmar Pedido</button>
                </div>
            </div>
        </div>
    </div>


    <div class="toast" id="toast"><i class="fas fa-check-circle"></i><span id="toastMessage">Item adicionado ao carrinho!</span></div>

    <!-- Modal de Confirmação Personalizado -->
    <div class="confirm-modal" id="confirmModal">
        <div class="confirm-content">
            <div class="confirm-header">
                <i class="fas fa-check-circle"></i>
                <h2>Pedido Confirmado!</h2>
                <p>Seu pedido foi recebido com sucesso</p>
            </div>
            <div class="confirm-body">
                <div class="pedido-number" id="confirmPedidoNumero">#0</div>
                <div class="pedido-info" id="confirmPedidoInfo"></div>
                <i class="fas fa-utensils" style="color: #f97316; font-size: 2rem; opacity: 0.5;"></i>
                <p style="margin-top: 1rem; font-size: 0.85rem; color: #94a3b8;">
                    Você receberá notificações em tempo real na aba <strong>Meus Pedidos</strong>.
                </p>
            </div>
            <div class="confirm-footer">
                <button class="confirm-btn confirm-btn-secondary" onclick="fecharConfirmModal(false)">
                    <i class="fas fa-times"></i> Fechar
                </button>
                <button class="confirm-btn confirm-btn-primary" onclick="fecharConfirmModal(true)">
                    <i class="fas fa-clipboard-list"></i> Acompanhar Pedido
                </button>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        // ==================== VARIÁVEIS ====================
        let carrinho = [];
        let produtos = {};
        let currentCategoria = 'todos';
        let clienteConnection = null;
        let toastTimeout;
        let telefoneClienteAtual = '';

                // Token global
        window.antiForgeryToken = '@requestToken';

        // Interceptar todos os fetches
        const originalFetch = window.fetch;
        window.fetch = function(url, options = {}) {
            if (options.method && ['POST', 'PUT', 'DELETE', 'PATCH'].includes(options.method.toUpperCase())) {
                options.headers = {
                    ...options.headers,
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': window.antiForgeryToken
                };
            }
            return originalFetch(url, options);
        };

        // ==================== INICIALIZAR PRODUTOS ====================
        function inicializarProdutos() {
            produtos = {};
            document.querySelectorAll('.menu-card').forEach(card => {
                const btn = card.querySelector('.btn-add');
                if (btn && btn.getAttribute('onclick')) {
                    const match = btn.getAttribute('onclick').match(/\d+/);
                    if (match) {
                        const id = parseInt(match[0]);
                        const nome = card.querySelector('h3').textContent;
                        const preco = parseFloat(card.querySelector('.menu-price').textContent.replace('R$', '').replace(',', '.'));
                        produtos[id] = { id, nome, preco };
                    }
                }
            });
        }

        // ==================== QUANTIDADE ====================
        function aumentarQtd(id) {
            const qtdSpan = document.getElementById(`qtd-${id}`);
            if (qtdSpan) {
                let qtd = parseInt(qtdSpan.textContent);
                qtd++;
                qtdSpan.textContent = qtd;
                const btn = document.getElementById(`btn-${id}`);
                if (btn) btn.disabled = false;
            }
        }

        function diminuirQtd(id) {
            const qtdSpan = document.getElementById(`qtd-${id}`);
            if (qtdSpan) {
                let qtd = parseInt(qtdSpan.textContent);
                if (qtd > 0) qtd--;
                qtdSpan.textContent = qtd;
                if (qtd === 0) {
                    const btn = document.getElementById(`btn-${id}`);
                    if (btn) btn.disabled = true;
                }
            }
        }

        // ==================== CARRINHO ====================
        function adicionarAoCarrinho(id) {
            const qtdSpan = document.getElementById(`qtd-${id}`);
            if (!qtdSpan) return;

            const qtd = parseInt(qtdSpan.textContent);
            if (qtd === 0) {
                showToast('Selecione uma quantidade!', 'warning');
                return;
            }

            const produto = produtos[id];
            if (!produto) return;

            const itemExistente = carrinho.find(item => item.id === id);
            if (itemExistente) {
                itemExistente.quantidade += qtd;
            } else {
                carrinho.push({
                    id: id,
                    nome: produto.nome,
                    preco: produto.preco,
                    quantidade: qtd
                });
            }

            qtdSpan.textContent = '0';
            const btn = document.getElementById(`btn-${id}`);
            if (btn) btn.disabled = true;

            atualizarCarrinho();
            showToast(`${produto.nome} adicionado ao carrinho!`);
        }

        function atualizarCarrinho() {
            const cartItems = document.getElementById('cartItems');
            const cartFooter = document.getElementById('cartFooter');
            const cartBadge = document.getElementById('cartBadge');

            let totalItens = 0;
            let totalValor = 0;

            if (carrinho.length === 0) {
                cartItems.innerHTML = `<div class="empty-cart"><i class="fas fa-shopping-basket"></i><h3>Carrinho vazio</h3><p>Adicione itens do cardápio</p></div>`;
                cartFooter.style.display = 'none';
                if (cartBadge) cartBadge.textContent = '0';
                return;
            }

            let html = '';
            carrinho.forEach((item, index) => {
                totalItens += item.quantidade;
                totalValor += item.preco * item.quantidade;

                html += `
                    <div class="cart-item">
                        <div class="cart-item-info">
                            <h4>${escapeHtml(item.nome)}</h4>
                            <span class="cart-item-price">R$ ${item.preco.toFixed(2)}</span>
                        </div>
                        <div class="cart-item-controls">
                            <button class="cart-qty-btn" onclick="alterarQuantidade(${index}, -1)">-</button>
                            <span>${item.quantidade}</span>
                            <button class="cart-qty-btn" onclick="alterarQuantidade(${index}, 1)">+</button>
                        </div>
                        <span class="cart-item-total">R$ ${(item.preco * item.quantidade).toFixed(2)}</span>
                        <button class="btn-remove" onclick="removerItem(${index})"><i class="fas fa-trash"></i></button>
                    </div>
                `;
            });

            cartItems.innerHTML = html;
            cartFooter.style.display = 'block';
            const cartTotal = document.getElementById('cartTotal');
            if (cartTotal) cartTotal.textContent = `R$ ${totalValor.toFixed(2)}`;
            if (cartBadge) cartBadge.textContent = totalItens;
        }

        function alterarQuantidade(index, delta) {
            const item = carrinho[index];
            if (!item) return;
            item.quantidade += delta;
            if (item.quantidade <= 0) {
                carrinho.splice(index, 1);
            }
            atualizarCarrinho();
        }

        function removerItem(index) {
            carrinho.splice(index, 1);
            atualizarCarrinho();
            showToast('Item removido do carrinho');
        }

        // ==================== FILTROS ====================
        function filtrarCategoria(categoria, element) {
            currentCategoria = categoria;
            document.querySelectorAll('.category-chip').forEach(chip => chip.classList.remove('active'));
            if (element) element.classList.add('active');
            aplicarFiltro();
        }

        function buscarProdutos() {
            aplicarFiltro();
        }

        function aplicarFiltro() {
            const termo = document.getElementById('searchInput')?.value.toLowerCase() || '';
            const cards = document.querySelectorAll('.menu-card');

            cards.forEach(card => {
                const cardCategoria = card.getAttribute('data-categoria');
                const cardNome = card.getAttribute('data-nome');

                const matchCategoria = currentCategoria === 'todos' || cardCategoria === currentCategoria;
                const matchBusca = !termo || (cardNome && cardNome.includes(termo));

                card.style.display = (matchCategoria && matchBusca) ? 'flex' : 'none';
            });
        }

        // ==================== UI ====================
        function toggleCart() {
            const cart = document.getElementById('cartSidebar');
            const overlay = document.getElementById('cartOverlay');
            if (cart) cart.classList.toggle('show');
            if (overlay) overlay.classList.toggle('show');
            document.body.style.overflow = cart?.classList.contains('show') ? 'hidden' : '';
        }

        function abrirModalIdentificacao() {
            if (carrinho.length === 0) {
                showToast('Adicione itens ao carrinho primeiro!', 'warning');
                return;
            }
            const modal = document.getElementById('identificacaoModal');
            if (modal) modal.classList.add('show');
        }

        function fecharModal() {
            const modal = document.getElementById('identificacaoModal');
            if (modal) modal.classList.remove('show');
        }

        // ==================== SIGNALR ====================
        function conectarSignalRCliente() {
            console.log("🔄 Iniciando conexão SignalR...");

            if (typeof signalR === 'undefined') {
                console.error("❌ SignalR não carregado! Verifique o CDN.");
                setTimeout(conectarSignalRCliente, 2000);
                return;
            }

            // Fecha conexão anterior se existir
            if (clienteConnection) {
                try {
                    clienteConnection.stop();
                } catch(e) {}
            }

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/pedidoHub")
                .withAutomaticReconnect([0, 2000, 5000, 10000])
                .configureLogging(signalR.LogLevel.Information)
                .build();

            // Eventos de conexão
            connection.onreconnecting(() => {
                console.warn("⚠️ SignalR reconectando...");
            });

            connection.onreconnected((connectionId) => {
                console.log("✅ SignalR reconectado! ID:", connectionId);
                entrarNoGrupoCliente(connection);
            });

            connection.onclose((error) => {
                console.warn("❌ SignalR fechado, tentará reconectar em 10s", error);
                setTimeout(conectarSignalRCliente, 10000);
            });

            // Evento de status do pedido
            connection.on("StatusAtualizado", function (data) {
                console.log("📢 Status do seu pedido:", data);
                let statusTexto = '';
                let icon = 'info';

                switch(data.status) {
                    case 'EM_PREPARACAO':
                        statusTexto = '🍖 Em preparo';
                        icon = 'warning';
                        break;
                    case 'PRONTO':
                        statusTexto = '✅ Pronto para retirar';
                        icon = 'success';
                        break;
                    case 'FINALIZADO':
                        statusTexto = '✔️ Finalizado';
                        icon = 'success';
                        break;
                    default:
                        statusTexto = '📝 Aguardando';
                        icon = 'info';
                }

                showToast(`Pedido #${data.codigo || data.id}: ${data.mensagem || statusTexto}`, icon);

                if (window.location.pathname.includes('/Usuario/MeusPedidos')) {
                    setTimeout(() => location.reload(), 1000);
                }
            });

            // Iniciar conexão
            connection.start()
                .then(() => {
                    console.log("✅ SignalR conectado com sucesso!");
                    console.log("Connection ID:", connection.connectionId);
                    clienteConnection = connection;

                    // Entrar no grupo do cliente
                    const telefone = localStorage.getItem('ultimoTelefone') || sessionStorage.getItem('telefoneCliente');
                    if (telefone) {
                        entrarNoGrupoCliente(connection, telefone);
                    }
                })

        }

        function entrarNoGrupoCliente(connection, telefone = null) {
            if (!telefone) {
                telefone = localStorage.getItem('ultimoTelefone') || sessionStorage.getItem('telefoneCliente');
            }

            if (telefone && connection && connection.state === signalR.HubConnectionState.Connected) {
                connection.invoke("EntrarGrupoCliente", telefone)
                    .then(() => console.log(`✅ Entrou no grupo do cliente: ${telefone}`))
                    .catch(err => console.error("❌ Erro ao entrar no grupo:", err));
            }
        }


        // ==================== FUNÇÃO PARA VALIDAR TELEFONE ====================
        function validarTelefone(telefone) {
            // Remove todos os caracteres não numéricos
            const numeros = telefone.replace(/\D/g, '');

            // Verifica se tem 11 dígitos (DDD + 9 dígitos)
            if (numeros.length !== 11) {
                return {
                    valido: false,
                    mensagem: 'Telefone inválido. Use DDD + 9 dígitos (ex: 11999999999)'
                };
            }

            // Verifica se o DDD é válido (11 a 99)
            const ddd = parseInt(numeros.substring(0, 2));
            if (ddd < 11 || ddd > 99) {
                return {
                    valido: false,
                    mensagem: 'DDD inválido. Use um DDD válido (11 a 99)'
                };
            }

            // Verifica se o primeiro dígito do número é 9 (celular)
            const primeiroDigito = numeros.charAt(2);
            if (primeiroDigito !== '9') {
                return {
                    valido: false,
                    mensagem: 'Número inválido. Use um número de celular com 9 dígitos (ex: 912345678)'
                };
            }

            return { valido: true, numeros: numeros };
        }

        // ==================== FUNÇÃO PARA FORMATAR TELEFONE ====================
        function formatarTelefone(telefone) {
            const numeros = telefone.replace(/\D/g, '');

            if (numeros.length === 11) {
                // Formato: (11) 91234-5678
                return numeros.replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
            } else if (numeros.length === 10) {
                // Formato: (11) 1234-5678 (fixo)
                return numeros.replace(/(\d{2})(\d{4})(\d{4})/, '($1) $2-$3');
            }

            return telefone; // Retorna como está se não conseguir formatar
        }

        // ==================== FINALIZAR PEDIDO ====================
        async function finalizarPedido() {
            const nome = document.getElementById('clienteNome')?.value.trim() || '';
            let telefone = document.getElementById('clienteTelefone')?.value.trim() || '';
            const observacoes = document.getElementById('clienteObs')?.value.trim() || '';
            const formaPagamento = document.querySelector('input[name="formaPagamento"]:checked')?.value;
            const tipoPedido = document.querySelector('input[name="tipoPedido"]:checked')?.value || 'CONSUMIR';

            if (!nome) {
                showToast('Por favor, digite seu nome', 'error');
                return;
            }

            if (!telefone) {
                showToast('Por favor, digite seu WhatsApp para contato', 'error');
                return;
            }

            const validacao = validarTelefone(telefone);
            if (!validacao.valido) {
                showToast(validacao.mensagem, 'error');
                return;
            }

            const telefoneNumeros = validacao.numeros;

            if (!formaPagamento) {
                showToast('Por favor, selecione uma forma de pagamento', 'error');
                return;
            }

            if (carrinho.length === 0) {
                showToast('Adicione itens ao carrinho primeiro!', 'warning');
                return;
            }

            showLoading();

            const itens = carrinho.map(item => ({
                IdProduto: item.id,
                NomeProduto: item.nome,
                Quantidade: item.quantidade,
                PrecoUnitario: item.preco
            }));

            const total = carrinho.reduce((acc, item) => acc + (item.preco * item.quantidade), 0);

            const pedido = {
                NomeCliente: nome,
                TelefoneCliente: telefoneNumeros,
                Observacoes: observacoes,
                FormaPagamento: formaPagamento,
                TipoPedido: tipoPedido,
                ValorTotal: total,
                Itens: itens
            };

            try {
                // 🔥 ADICIONAR O TOKEN CSRF NO HEADER
                const token = window.antiForgeryToken || document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                const response = await fetch('/Usuario/FinalizarPedido', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token  // 🔥 ENVIAR O TOKEN!
                    },
                    body: JSON.stringify(pedido)
                });

                const data = await response.json();
                hideLoading();

                if (data.success) {
                    localStorage.setItem('ultimoTelefone', telefoneNumeros);
                    sessionStorage.setItem('telefoneCliente', telefoneNumeros);
                    telefoneClienteAtual = telefoneNumeros;

                    carrinho = [];
                    atualizarCarrinho();
                    fecharModal();

                    if (document.getElementById('cartSidebar')?.classList.contains('show')) {
                        toggleCart();
                    }

                    document.getElementById('clienteNome').value = '';
                    document.getElementById('clienteTelefone').value = '';
                    if (document.getElementById('clienteObs')) {
                        document.getElementById('clienteObs').value = '';
                    }
                    if (document.querySelectorAll('input[name="formaPagamento"]').length > 0) {
                        document.querySelectorAll('input[name="formaPagamento"]')[0].checked = true;
                    }

                    showConfirmModal(data.codigoPedido || data.codigo, telefoneNumeros);

                } else {
                    showToast(data.message || 'Erro ao finalizar pedido', 'error');
                }
            } catch (error) {
                console.error('Erro:', error);
                hideLoading();
                showToast('Erro ao finalizar pedido. Tente novamente.', 'error');
            }
        }

                // ==================== MODAL DE CONFIRMAÇÃO ====================
        let confirmCallback = null;

        function showConfirmModal(pedidoNumero, telefone) {
            const modal = document.getElementById('confirmModal');
            const numeroSpan = document.getElementById('confirmPedidoNumero');
            const infoSpan = document.getElementById('confirmPedidoInfo');

            if (numeroSpan) numeroSpan.textContent = `#${pedidoNumero}`;
            if (infoSpan) infoSpan.textContent = `Seu pedido #${pedidoNumero} está sendo preparado!`;

            // Salvar telefone para uso depois
            window.telefoneParaAcompanhar = telefone;

            // Mostrar modal
            if (modal) modal.classList.add('show');

            // Efeito de confete
            criarConfetes();

            // Tocar som (opcional)
            try {
                const audio = new Audio('/sounds/success.mp3');
                audio.play().catch(e => console.log("Som não suportado"));
            } catch(e) {}
        }

        function fecharConfirmModal(acompanhar) {
            const modal = document.getElementById('confirmModal');
            if (modal) modal.classList.remove('show');

            if (acompanhar && window.telefoneParaAcompanhar) {
                window.location.href = `/Usuario/MeusPedidos?telefone=${encodeURIComponent(window.telefoneParaAcompanhar)}`;
            } else if (!acompanhar) {
                // Recarregar a página para limpar o carrinho
                location.reload();
            }
        }

        function criarConfetes() {
            const colors = ['#f97316', '#10b981', '#06b6d4', '#8b5cf6', '#ef4444'];
            for (let i = 0; i < 100; i++) {
                setTimeout(() => {
                    const confetti = document.createElement('div');
                    confetti.className = 'confetti';
                    confetti.style.left = Math.random() * 100 + '%';
                    confetti.style.width = (Math.random() * 8 + 4) + 'px';
                    confetti.style.height = (Math.random() * 12 + 8) + 'px';
                    confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                    confetti.style.animationDuration = (Math.random() * 2 + 2) + 's';
                    document.body.appendChild(confetti);

                    setTimeout(() => confetti.remove(), 3000);
                }, i * 30);
            }
        }

        // Fechar modal ao clicar fora
        document.addEventListener('click', function(e) {
            const modal = document.getElementById('confirmModal');
            if (e.target === modal) {
                fecharConfirmModal(false);
            }
        });


        // ==================== UTILITÁRIOS ====================
        function showLoading() {
            const loading = document.getElementById('loadingBar');
            if (loading) loading.style.display = 'block';
        }

        function hideLoading() {
            const loading = document.getElementById('loadingBar');
            if (loading) loading.style.display = 'none';
        }

        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            if (!toast) return;

            const icon = toast.querySelector('i');
            if (icon) {
                icon.className = type === 'success' ? 'fas fa-check-circle' : type === 'error' ? 'fas fa-exclamation-circle' : 'fas fa-info-circle';
            }
            const msgSpan = document.getElementById('toastMessage');
            if (msgSpan) msgSpan.textContent = message;

            if (toastTimeout) clearTimeout(toastTimeout);

            toast.classList.add('show');
            toastTimeout = setTimeout(() => {
                toast.classList.remove('show');
            }, 4000);
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // ==================== FUNÇÃO PARA ACOMPANHAR PEDIDOS ====================
        function verMeusPedidos() {
            const telefone = document.getElementById('clienteTelefone')?.value.trim() || '';
            if (telefone) {
                window.location.href = `/Usuario/MeusPedidos?telefone=${encodeURIComponent(telefone)}`;
            } else {
                window.location.href = `/Usuario/MeusPedidos}`;
            }
        }

        // ==================== AMPLIAR FOTO DO ESTABELECIMENTO ====================
        function ampliarFotoEstabelecimento() {
            const photoImg = document.querySelector('.establishment-photo img');
            if (photoImg && photoImg.src && !photoImg.src.includes('via.placeholder.com')) {
                const modal = document.createElement('div');
                modal.style.position = 'fixed';
                modal.style.top = '0';
                modal.style.left = '0';
                modal.style.width = '100%';
                modal.style.height = '100%';
                modal.style.background = 'rgba(0,0,0,0.9)';
                modal.style.zIndex = '5000';
                modal.style.display = 'flex';
                modal.style.alignItems = 'center';
                modal.style.justifyContent = 'center';
                modal.style.cursor = 'pointer';
                modal.innerHTML = `<img src="${photoImg.src}" style="max-width: 90%; max-height: 90%; border-radius: 20px; box-shadow: 0 0 50px rgba(0,0,0,0.5);">`;
                modal.onclick = () => modal.remove();
                document.body.appendChild(modal);
            } else {
                showToast('Nenhuma foto cadastrada', 'info');
            }
        }

        // ==================== CARREGAR DADOS DO ESTABELECIMENTO ====================
        async function carregarDadosEstabelecimento() {
            try {
                const response = await fetch('/Estabelecimento/ObterDaSessao');
                const data = await response.json();

                if (data.success && data.existe) {
                    const appTitle = document.querySelector('.app-title h1');
                    const photoImg = document.querySelector('.establishment-photo img');
                    const photoIcon = document.querySelector('.establishment-photo i');
                    const heroMessage = document.querySelector('.hero p');

                    if (appTitle && data.nome) {
                        appTitle.textContent = data.nome;
                    }

                    if (data.imagem && data.imagem !== '') {
                        if (photoImg) {
                            photoImg.src = data.imagem;
                            photoImg.style.display = 'block';
                            if (photoIcon) photoIcon.style.display = 'none';
                        }
                    } else if (photoIcon) {
                        photoIcon.style.display = 'flex';
                        if (photoImg) photoImg.style.display = 'none';
                    }

                    if (heroMessage && data.mensagemHero) {
                        heroMessage.textContent = data.mensagemHero;
                    }
                }
            } catch (error) {
                console.error('Erro ao carregar dados do estabelecimento:', error);
            }
        }

        // ==================== EVENT LISTENERS ====================

        // Ampliar foto ao clicar
        document.querySelector('.establishment-photo')?.addEventListener('click', function(e) {
            e.stopPropagation();
            ampliarFotoEstabelecimento();
        });

        // Máscara telefone
        // Máscara telefone (atualizada para aceitar 9 dígitos)
        const telefoneInput = document.getElementById('clienteTelefone');
        if (telefoneInput) {
            telefoneInput.addEventListener('input', function(e) {
                let value = e.target.value.replace(/\D/g, '');

                // Limitar a 11 dígitos
                if (value.length > 11) {
                    value = value.slice(0, 11);
                }

                // Aplicar máscara
                if (value.length <= 11) {
                    if (value.length > 0) {
                        // Formato: (DDD) 9XXXX-XXXX
                        if (value.length <= 2) {
                            value = value.replace(/^(\d{0,2})/, '($1');
                        } else if (value.length <= 3) {
                            value = value.replace(/^(\d{2})(\d{0,1})/, '($1) $2');
                        } else if (value.length <= 7) {
                            value = value.replace(/^(\d{2})(\d{0,5})/, '($1) $2');
                        } else if (value.length <= 11) {
                            value = value.replace(/^(\d{2})(\d{5})(\d{0,4})/, '($1) $2-$3');
                        }
                    }
                    e.target.value = value;
                }

                // Validar em tempo real
                const validacao = validarTelefone(value);
                if (value.length === 14 || value.length === 15) { // Tamanho com formatação
                    if (!validacao.valido) {
                        e.target.style.borderColor = '#ef4444';
                        e.target.title = validacao.mensagem;
                    } else {
                        e.target.style.borderColor = '#10b981';
                        e.target.title = '';
                    }
                } else {
                    e.target.style.borderColor = '';
                }
            });
        }


                    // Adicionar botão "Meus Pedidos" no modal
            const modalFooter = document.querySelector('#identificacaoModal .modal-footer');
            if (modalFooter) {
                const btnMeusPedidos = document.createElement('button');
                btnMeusPedidos.className = 'btn btn-secondary';
                btnMeusPedidos.innerHTML = '<i class="fas fa-clipboard-list"></i> Meus Pedidos';
                btnMeusPedidos.onclick = verMeusPedidos;
                modalFooter.appendChild(btnMeusPedidos);
            }


        // ==================== FUNÇÃO PARA ACOMPANHAR PEDIDOS ====================
        function verMeusPedidos() {
            // Tenta pegar o telefone do campo do modal
            let telefone = document.getElementById('clienteTelefone')?.value.trim() || '';

            // Se não tiver no campo, tenta pegar do localStorage
            if (!telefone) {
                telefone = localStorage.getItem('ultimoTelefone') || '';
            }

            // Se ainda não tiver, tenta pegar do sessionStorage
            if (!telefone) {
                telefone = sessionStorage.getItem('telefoneCliente') || '';
            }

            if (telefone) {
                // Tem telefone salvo, vai direto para os pedidos
                window.location.href = `/Usuario/MeusPedidos?telefone=${encodeURIComponent(telefone)}`;
            } else {
                // Não tem telefone, vai para a página de busca
                window.location.href = `/Usuario/MeusPedidos`;
            }
        }


                // ==================== AJUSTAR ALTURA DO CARRINHO EM CELULAR ====================
        function ajustarAlturaCarrinho() {
            const cartSidebar = document.getElementById('cartSidebar');
            const cartFooter = document.getElementById('cartFooter');
            const cartHeader = document.querySelector('.cart-header');

            if (!cartSidebar) return;

            // Calcular altura disponível
            const windowHeight = window.innerHeight;
            const headerHeight = cartHeader?.offsetHeight || 80;
            const footerHeight = cartFooter?.offsetHeight || 100;
            const availableHeight = windowHeight - headerHeight - footerHeight;

            const cartItems = document.getElementById('cartItems');
            if (cartItems) {
                cartItems.style.maxHeight = `${availableHeight}px`;
                cartItems.style.minHeight = `${Math.min(200, availableHeight)}px`;
            }
        }

        // Chamar quando o carrinho abrir e ao redimensionar
        function toggleCart() {
            const cart = document.getElementById('cartSidebar');
            const overlay = document.getElementById('cartOverlay');
            if (cart) cart.classList.toggle('show');
            if (overlay) overlay.classList.toggle('show');
            document.body.style.overflow = cart?.classList.contains('show') ? 'hidden' : '';

            // Ajustar altura quando abrir
            if (cart?.classList.contains('show')) {
                setTimeout(ajustarAlturaCarrinho, 100);
            }
        }

        // Evento de redimensionamento da tela
        window.addEventListener('resize', function() {
            if (document.getElementById('cartSidebar')?.classList.contains('show')) {
                ajustarAlturaCarrinho();
            }
        });


        // ==================== INICIALIZAR ====================
        document.addEventListener('DOMContentLoaded', function() {
            carregarDadosEstabelecimento();
            inicializarProdutos();
            conectarSignalRCliente();
            aplicarFiltro();

        });
    </script>
